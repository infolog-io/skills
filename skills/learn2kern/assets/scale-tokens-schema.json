{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infolog.io/schemas/learn2kern-scale-tokens.json",
  "title": "Type Scale Tokens",
  "description": "Canonical structured output of learn2kern. Captures the scale plus BODY and HEADINGS token families.",
  "type": "object",
  "required": ["scale", "line_heights", "letter_spacing", "body", "headings"],
  "additionalProperties": false,
  "properties": {
    "scale": {
      "type": "object",
      "required": ["base_px", "ratio", "ratio_name", "steps"],
      "additionalProperties": false,
      "properties": {
        "base_px": { "type": "number", "exclusiveMinimum": 0 },
        "ratio": { "type": "number", "exclusiveMinimum": 1 },
        "ratio_name": {
          "enum": [
            "Minor Second",
            "Major Second",
            "Minor Third",
            "Major Third",
            "Perfect Fourth",
            "Augmented Fourth",
            "Perfect Fifth",
            "Golden Ratio",
            "Custom"
          ]
        },
        "steps_up": { "type": "integer", "minimum": 0 },
        "steps_down": { "type": "integer", "minimum": 0 },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["step", "px", "rem", "pt"],
            "additionalProperties": false,
            "properties": {
              "step": { "type": "integer" },
              "name": { "type": "string" },
              "px": { "type": "number", "exclusiveMinimum": 0 },
              "rem": { "type": "number", "exclusiveMinimum": 0 },
              "pt": { "type": "number", "exclusiveMinimum": 0 }
            }
          }
        }
      }
    },
    "line_heights": {
      "type": "object",
      "required": ["body", "heading", "display"],
      "additionalProperties": false,
      "properties": {
        "body":    { "type": "number", "exclusiveMinimum": 0 },
        "heading": { "type": "number", "exclusiveMinimum": 0 },
        "display": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "letter_spacing": {
      "type": "object",
      "required": ["body", "heading", "display"],
      "additionalProperties": false,
      "properties": {
        "body":    { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?(em|rem|px)$" },
        "heading": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?(em|rem|px)$" },
        "display": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?(em|rem|px)$" }
      }
    },
    "body": {
      "$ref": "#/$defs/typeFamily"
    },
    "headings": {
      "$ref": "#/$defs/typeFamily"
    },
    "emissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "css": { "type": "string" },
        "tailwind_js": { "type": "string" }
      }
    }
  },
  "$defs": {
    "typeFamily": {
      "type": "object",
      "required": ["family", "weight", "line_height", "letter_spacing", "color"],
      "additionalProperties": false,
      "properties": {
        "family": { "type": "string", "minLength": 1 },
        "weight": { "type": "integer", "minimum": 100, "maximum": 900 },
        "line_height": { "type": ["number", "string"] },
        "letter_spacing": { "type": "string" },
        "color": { "type": "string", "minLength": 1 }
      }
    }
  }
}
