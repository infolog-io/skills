{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infolog.io/schemas/jtbd-statement.json",
  "title": "JTBD Statement",
  "description": "A single Jobs-to-be-Done statement with evidence and dimension tags.",
  "type": "object",
  "required": ["id", "context", "motivation", "outcome", "evidence", "confidence", "dimensions"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^JOB-[0-9]{3,}$",
      "description": "Stable identifier, e.g., JOB-001"
    },
    "label": {
      "type": "string",
      "minLength": 3,
      "maxLength": 80,
      "description": "Short human-readable handle for the job"
    },
    "context": {
      "type": "string",
      "minLength": 20,
      "description": "The triggering situation — when..."
    },
    "motivation": {
      "type": "string",
      "minLength": 10,
      "description": "Verb + object the customer is reaching for"
    },
    "outcome": {
      "type": "string",
      "minLength": 15,
      "description": "Observable progress made when motivation is satisfied"
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_id", "quote", "confidence"],
        "additionalProperties": false,
        "properties": {
          "source_id": { "type": "string" },
          "role": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "quote": { "type": "string", "minLength": 1 },
          "confidence": { "enum": ["high", "medium", "low"] }
        }
      }
    },
    "confidence": {
      "enum": ["high", "medium", "low"],
      "description": "Aggregate confidence across all evidence"
    },
    "dimensions": {
      "type": "object",
      "required": ["functional"],
      "additionalProperties": false,
      "properties": {
        "functional": { "type": "string", "minLength": 10 },
        "emotional": { "type": ["string", "null"] },
        "social": { "type": ["string", "null"] }
      }
    },
    "outcome_statements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["direction", "unit_of_measure", "object_of_control"],
        "additionalProperties": false,
        "properties": {
          "direction": { "enum": ["Minimize", "Increase", "Reduce"] },
          "unit_of_measure": { "type": "string" },
          "object_of_control": { "type": "string" },
          "contextual_clarifier": { "type": "string" }
        }
      }
    },
    "related_jobs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^JOB-[0-9]{3,}$" }
    }
  }
}
